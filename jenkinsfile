pipeline {
    agent any
    stages {
        stage('清理workspace') {

            steps {

                deleteDir()

            }

        }
        stage('拉取代码') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/dawang1213/myngdemo.git'
            }
        }
        stage('Docker构建') {

            steps {
                sh '''
                docker build -t dawang1213/nginx-demo:v3 .
                '''
            }
        }
        stage('Docker登录') {


            steps {


                sh '''
                docker login -u dawang1213 -p Qwerty@1213
                '''


            }

        }
        stage('推送镜像') {


            steps {


                sh '''
                docker push dawang1213/nginx-demo:v3
                '''


            }

        }
        
    }
}